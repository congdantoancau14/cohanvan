ile-name-header"><div dir="ltr"><div style="text-align:center"><span style="color:rgb(255,0,0);font-size:xx-large;line-height:1.5;background-color:transparent">村居</span></div><div style="text-align:center"><span style="background-color:transparent"><font color="#ff0000" face="times new roman, serif" size="5">Thôn cư </font></span></div><div style="text-align:center"><br /></div><div style="text-align:center"><font face="times new roman, serif" size="4"><span style="background-color:transparent">阮鬯</span></font></div><div style="text-align:center"><font face="times new roman, serif" size="4"><span style="background-color:transparent">NGUYỄN SƯỞNG</span></font></div><div style="text-align:center"><font face="times new roman, serif" size="4"><span style="background-color:transparent"><br /></span></font></div></div></div><div class="sites-layout-tile sites-tile-name-content-1"><div dir="ltr"><br /><div dir="ltr"><div align="center"><div align="center"><div align="center"><div align="center"><div align="center">

<table border="0" cellpadding="0" cellspacing="0" style="border-collapse:collapse">
 <tbody><tr>
  <td style="padding:.75pt 5.65pt .75pt 5.65pt" valign="top">
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">匆 匆 春 已
  夏</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">樹 底 鳥 聲
  忙</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">簷 月 移 花
  影</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">窗 風 借 竹
  涼</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">圍 棋 閒 得
  地</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">對 酒 醉 為
  鄉</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">喚 出 華 胥
  國</span></font></p>
  <p><font color="#0000ff" face="times new roman, serif" size="5"><span lang="ZH-TW">鄰 雞 隔 短
  牆</span></font></p>
  </td>
  <td style="padding:.75pt 5.65pt .75pt 5.65pt" valign="top">
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Thông thông xuân dĩ hạ,</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Thụ để điểu thanh mang.</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Thiềm nguyệt di hoa ảnh,</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Song phong tá trúc lương.</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Vi kỳ nhàn đắc địa,</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Ðối tửu tuý vi hương.</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Hoán xuất Hoa Tư quốc,</font></span></p>
  <p><span lang="VI"><font color="#0000ff" face="times new roman, serif" size="5">Lân kê cách đoản tường.</font></span></p>
  </td>
 </tr>
</tbody></table>

